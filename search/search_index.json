b294 \uc644\ud654\ucc45\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"security/sample3/","title":"checkimagetag(example)","text":""},{"location":"security/sample3/#meaning","title":"Meaning","text":"<p>\uc774 \uae30\ub2a5\uc758 \uc758\ubbf8\ub97c \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"security/sample3/#impact","title":"Impact","text":"<p>\uc774 \uae30\ub2a5\uc774 \uc601\ud5a5\uc744 \ubbf8\uce58\ub294 \uc601\uc5ed\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"security/sample3/#diagnosis","title":"Diagnosis","text":"<p>\uc774 \uae30\ub2a5\uc758 \uc0c1\ud0dc\ub97c \uc9c4\ub2e8\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"security/sample3/#mitigation","title":"Mitigation","text":"<p>\uc774 \uae30\ub2a5\uc5d0 \ubb38\uc81c\uac00 \ubc1c\uc0dd\ud588\uc744 \ub54c \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc644\ud654\ucc45\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"stability/sample4/","title":"checkimagetag(example)","text":""},{"location":"stability/sample4/#meaning","title":"Meaning","text":"<p>\uc774 \uae30\ub2a5\uc758 \uc758\ubbf8\ub97c \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"stability/sample4/#impact","title":"Impact","text":"<p>\uc774 \uae30\ub2a5\uc774 \uc601\ud5a5\uc744 \ubbf8\uce58\ub294 \uc601\uc5ed\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"stability/sample4/#diagnosis","title":"Diagnosis","text":"<p>\uc774 \uae30\ub2a5\uc758 \uc0c1\ud0dc\ub97c \uc9c4\ub2e8\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"stability/sample4/#mitigation","title":"Mitigation","text":"<p>\uc774 \uae30\ub2a5\uc5d0 \ubb38\uc81c\uac00 \ubc1c\uc0dd\ud588\uc744 \ub54c \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc644\ud654\ucc45\uc744 \uc124\uba85\ud569\ub2c8\ub2e4.</p>"},{"location":"stability/%EC%8B%B1%EA%B8%80%ED%86%A4%20Pod%20%EB%AF%B8%EC%82%AC%EC%9A%A9/","title":"\uc2f1\uae00\ud1a4 Pod \ubbf8\uc0ac\uc6a9 (Singleton Pod Usage Detection)","text":""},{"location":"stability/%EC%8B%B1%EA%B8%80%ED%86%A4%20Pod%20%EB%AF%B8%EC%82%AC%EC%9A%A9/#meaning","title":"Meaning","text":"<p>\uc2f1\uae00\ud1a4 Pod(Singleton Pod)\ub294 \ud074\ub7ec\uc2a4\ud130 \ub0b4\uc5d0\uc11c \ub2e8 \ud558\ub098\uc758 \uc778\uc2a4\ud134\uc2a4\ub9cc \uc2e4\ud589\ub418\ub294 Pod\uc785\ub2c8\ub2e4. \uc774 \ubc29\uc2dd\uc740 \uace0\uac00\uc6a9\uc131(HA) \ubc0f \ud655\uc7a5\uc131\uc744 \uc800\ud574\ud558\uba70, \uc7a5\uc560 \ubc1c\uc0dd \uc2dc \uc11c\ube44\uc2a4 \uc911\ub2e8\uc744 \ucd08\ub798\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"stability/%EC%8B%B1%EA%B8%80%ED%86%A4%20Pod%20%EB%AF%B8%EC%82%AC%EC%9A%A9/#impact","title":"Impact","text":"<ul> <li>\ub178\ub4dc \uc7a5\uc560 \uc2dc \uc11c\ube44\uc2a4 \uc911\ub2e8 \ubc1c\uc0dd</li> <li>\uc790\ub3d9 \ud655\uc7a5(HPA) \ubd88\uac00\ub2a5, \ud2b8\ub798\ud53d \uc99d\uac00 \ub300\uc751 \ubd88\uac00</li> <li>\ub864\ub9c1 \uc5c5\ub370\uc774\ud2b8 \uc801\uc6a9 \ubd88\uac00 \u2192 \ub2e4\uc6b4\ud0c0\uc784 \uc99d\uac00</li> <li>\ud2b9\uc815 \ub178\ub4dc\uc5d0 \uc885\uc18d\ub420 \uacbd\uc6b0 \ubcf5\uad6c \uc9c0\uc5f0 \ubc1c\uc0dd</li> </ul>"},{"location":"stability/%EC%8B%B1%EA%B8%80%ED%86%A4%20Pod%20%EB%AF%B8%EC%82%AC%EC%9A%A9/#diagnosis","title":"Diagnosis","text":"<p>\uc2f1\uae00\ud1a4 Pod\uac00 \uc874\uc7ac\ud558\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.</p> <pre><code>kubectl get deployments,statefulsets -A | awk '$3 == 1 {print}'\nkubectl get pods -A --field-selector=status.phase=Running | grep -v \"ReplicaSet\"\nkubectl get hpa -A\nkubectl describe pod &lt;pod-name&gt; | grep -i \"nodeName\"\n</code></pre>"},{"location":"stability/%EC%8B%B1%EA%B8%80%ED%86%A4%20Pod%20%EB%AF%B8%EC%82%AC%EC%9A%A9/#mitigation","title":"Mitigation","text":"<p>\uc2f1\uae00\ud1a4 Pod\ub97c \uc81c\uac70\ud558\uace0 HA \uad6c\uc131\uc744 \uc801\uc6a9\ud558\uc138\uc694.</p> <ul> <li>Deployment\ub85c \ubcc0\ud658 \ud6c4 replicas: 2 \uc774\uc0c1 \uc124\uc815</li> </ul> <pre><code>apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: my-app\nspec:\n  replicas: 3\n  selector:\n    matchLabels:\n      app: my-app\n  template:\n    metadata:\n      labels:\n        app: my-app\n    spec:\n      containers:\n        - name: app-container\n          image: my-app-image\n</code></pre> <ul> <li>HPA \uc801\uc6a9</li> </ul> <pre><code>kubectl autoscale deployment my-app --cpu-percent=50 --min=2 --max=10\n</code></pre> <ul> <li>\uc218\ub3d9 \uc2e4\ud589\ub41c Singleton Pod \uc81c\uac70</li> </ul> <pre><code>kubectl delete pod &lt;pod-name&gt; -n &lt;namespace&gt;\n</code></pre>"}]}